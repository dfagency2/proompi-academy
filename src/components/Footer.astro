---
interface Props {
  lang: string;
}
const { lang } = Astro.props;
const isEn = lang === 'en';
const base = isEn ? '/en' : '';

const sections = isEn ? [
  { label: 'Getting Started', href: `${base}/getting-started` },
  { label: 'Prompt Enhancement', href: `${base}/prompt-enhancement` },
  { label: 'Image Generation', href: `${base}/image-generation` },
  { label: 'Workflow Builder', href: `${base}/workflows` },
  { label: 'Video Generation', href: `${base}/video-generation` },
  { label: 'Music Generation', href: `${base}/music-generation` },
  { label: 'Graphics Editing', href: `${base}/graphics-editing` },
  { label: 'Plans & Credits', href: `${base}/plans-credits` },
  { label: 'Tips & Tricks', href: `${base}/tips` },
] : [
  { label: 'Pierwsze kroki', href: `${base}/getting-started` },
  { label: 'Ulepszanie Promptów', href: `${base}/prompt-enhancement` },
  { label: 'Generowanie Obrazów', href: `${base}/image-generation` },
  { label: 'Workflow Builder', href: `${base}/workflows` },
  { label: 'Generowanie Wideo', href: `${base}/video-generation` },
  { label: 'Generowanie Muzyki', href: `${base}/music-generation` },
  { label: 'Edycja Grafik', href: `${base}/graphics-editing` },
  { label: 'Plany i Kredyty', href: `${base}/plans-credits` },
  { label: 'Tips i Triki', href: `${base}/tips` },
];
---

<footer class="mt-20 border-t border-neutral-200 bg-white/60">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 bg-primary-500 rounded-xl flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M9 2L3 6v6l6 4 6-4V6L9 2z" fill="white" opacity="0.9"/>
              <path d="M9 2v10M3 6l6 4 6-4" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="font-bold text-neutral-900">Proompi Academy</span>
        </div>
        <p class="text-sm text-neutral-500 leading-relaxed max-w-xs">
          {isEn
            ? 'Official knowledge base for Proompi users. Learn to create stunning AI-generated content.'
            : 'Oficjalna baza wiedzy dla użytkowników Proompi. Naucz się tworzyć treści AI jak ekspert.'}
        </p>
        <a
          href="https://proompi.com"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 mt-4 text-sm font-medium text-primary-500 hover:text-primary-600"
        >
          proompi.com →
        </a>
      </div>

      <!-- Sekcje -->
      <div>
        <h3 class="text-sm font-semibold text-neutral-900 uppercase tracking-wider mb-4">
          {isEn ? 'Guides' : 'Przewodniki'}
        </h3>
        <ul class="space-y-2">
          {sections.slice(0, 5).map(s => (
            <li>
              <a href={s.href} class="text-sm text-neutral-500 hover:text-primary-500 transition-colors">{s.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-neutral-900 uppercase tracking-wider mb-4">
          {isEn ? 'More' : 'Więcej'}
        </h3>
        <ul class="space-y-2">
          {sections.slice(5).map(s => (
            <li>
              <a href={s.href} class="text-sm text-neutral-500 hover:text-primary-500 transition-colors">{s.label}</a>
            </li>
          ))}
          <li class="pt-2">
            <a href={isEn ? '/' : '/en'} class="text-sm text-neutral-500 hover:text-primary-500 transition-colors">
              {isEn ? '🇵🇱 Wersja polska' : '🇬🇧 English version'}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-neutral-200 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-neutral-400">
        © {new Date().getFullYear()} Proompi. {isEn ? 'All rights reserved.' : 'Wszelkie prawa zastrzeżone.'}
      </p>
      <div class="flex items-center gap-4">
        <a href="https://proompi.com/privacy" class="text-xs text-neutral-400 hover:text-neutral-600">
          {isEn ? 'Privacy' : 'Prywatność'}
        </a>
        <a href="https://proompi.com/terms" class="text-xs text-neutral-400 hover:text-neutral-600">
          {isEn ? 'Terms' : 'Regulamin'}
        </a>
      </div>
    </div>
  </div>
</footer>
