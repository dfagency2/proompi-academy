---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'docs'>;
  lang: string;
}

const { article, lang } = Astro.props;
const { data } = article;
const isEn = lang === 'en';
const base = isEn ? '/en' : '';

const slugParts = article.slug.split('/');
const path = slugParts.slice(1).join('/');
const href = `${base}/${path}`;

// Section-specific gradient for the thumbnail strip
const sectionGradients: Record<string, string> = {
  'getting-started':   'from-emerald-400 to-teal-300',
  'prompt-enhancement':'from-violet-500 to-purple-400',
  'image-generation':  'from-blue-500 to-indigo-400',
  'workflows':         'from-indigo-500 to-blue-400',
  'video-generation':  'from-rose-500 to-pink-400',
  'music-generation':  'from-orange-400 to-amber-300',
  'graphics-editing':  'from-teal-500 to-cyan-400',
  'plans-credits':     'from-amber-400 to-yellow-300',
  'tips':              'from-neutral-400 to-slate-300',
};

const sectionIcons: Record<string, string> = {
  'getting-started':   '🚀',
  'prompt-enhancement':'✨',
  'image-generation':  '🖼️',
  'workflows':         '⚡',
  'video-generation':  '🎬',
  'music-generation':  '🎵',
  'graphics-editing':  '🎨',
  'plans-credits':     '💳',
  'tips':              '💡',
};

const gradient = sectionGradients[data.section] ?? 'from-neutral-400 to-slate-300';
const icon = sectionIcons[data.section] ?? '📄';
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-2xl border border-white/60 bg-white hover:shadow-float transition-all duration-300 hover:-translate-y-1"
  style="box-shadow: 0 2px 12px -2px rgba(0,0,0,0.06);"
>
  <!-- Gradient thumbnail strip -->
  <div class:list={['h-20 bg-gradient-to-br flex items-center justify-center relative overflow-hidden', gradient]}>
    <span class="text-3xl drop-shadow-sm z-10">{icon}</span>
    <!-- Abstract decorative circles -->
    <div class="absolute -top-4 -right-4 w-16 h-16 rounded-full bg-white/10"></div>
    <div class="absolute -bottom-6 -left-2 w-20 h-20 rounded-full bg-white/10"></div>
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col gap-2 flex-1">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-semibold text-neutral-900 group-hover:text-violet-700 transition-colors leading-snug text-[15px]">
        {data.title}
      </h3>
      {data.badge && (
        <span class="text-xs bg-violet-50 text-violet-600 font-semibold px-2 py-0.5 rounded-full flex-shrink-0 border border-violet-100">
          {data.badge}
        </span>
      )}
    </div>
    <p class="text-sm text-neutral-500 leading-relaxed line-clamp-2 flex-1">
      {data.description}
    </p>
    <span class="text-xs font-semibold text-violet-600 mt-1">
      {isEn ? 'Read guide →' : 'Czytaj →'}
    </span>
  </div>
</a>
