---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'docs'>;
  lang: string;
}

const { article, lang } = Astro.props;
const { data } = article;
const isEn = lang === 'en';
const base = isEn ? '/en' : '';

const slugParts = article.slug.split('/');
const path = slugParts.slice(1).join('/');
const href = `${base}/${path}`;

const sectionIcons: Record<string, string> = {
  'getting-started': '🚀',
  'prompt-enhancement': '✨',
  'image-generation': '🖼️',
  'workflows': '⚡',
  'video-generation': '🎬',
  'music-generation': '🎵',
  'graphics-editing': '🎨',
  'plans-credits': '💳',
  'tips': '💡',
};

const icon = sectionIcons[data.section] ?? '📄';
---

<a
  href={href}
  class="glass-card p-5 flex flex-col gap-3 hover:shadow-float transition-all duration-200 hover:-translate-y-0.5 group"
>
  <div class="flex items-start justify-between gap-2">
    <span class="text-2xl" aria-hidden="true">{icon}</span>
    {data.badge && (
      <span class="text-xs bg-primary-50 text-primary-600 font-semibold px-2 py-0.5 rounded-full flex-shrink-0">
        {data.badge}
      </span>
    )}
  </div>

  <div>
    <h3 class="font-semibold text-neutral-900 group-hover:text-primary-600 transition-colors leading-snug">
      {data.title}
    </h3>
    <p class="mt-1.5 text-sm text-neutral-500 leading-relaxed line-clamp-2">
      {data.description}
    </p>
  </div>

  <span class="text-xs font-medium text-primary-500 mt-auto">
    {isEn ? 'Read guide →' : 'Czytaj →'}
  </span>
</a>
