---
interface Props {
  lang: string;
}
const { lang } = Astro.props;

const isEn = lang === 'en';
const base = isEn ? '/en' : '';

const nav = isEn ? [
  { label: 'Getting Started', href: `${base}/getting-started` },
  { label: 'Workflows', href: `${base}/workflows` },
  { label: 'Image Gen', href: `${base}/image-generation` },
  { label: 'Video', href: `${base}/video-generation` },
  { label: 'Tips', href: `${base}/tips` },
] : [
  { label: 'Pierwsze kroki', href: `${base}/getting-started` },
  { label: 'Workflow', href: `${base}/workflows` },
  { label: 'Generowanie Obrazów', href: `${base}/image-generation` },
  { label: 'Wideo', href: `${base}/video-generation` },
  { label: 'Tips', href: `${base}/tips` },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 glass border-b border-white/50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between gap-4">
    <!-- Logo -->
    <a href={isEn ? '/en' : '/'} class="flex items-center gap-2.5 flex-shrink-0">
      <div class="w-8 h-8 bg-primary-500 rounded-xl flex items-center justify-center">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M9 2L3 6v6l6 4 6-4V6L9 2z" fill="white" opacity="0.9"/>
          <path d="M9 2v10M3 6l6 4 6-4" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="font-bold text-neutral-900 text-lg leading-none">
        Proompi <span class="text-primary-500">Academy</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-1">
      {nav.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[
              'px-3 py-1.5 rounded-xl text-sm font-medium transition-colors duration-150',
              currentPath.startsWith(item.href)
                ? 'bg-primary-50 text-primary-600'
                : 'text-neutral-600 hover:text-neutral-900 hover:bg-neutral-100'
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right actions -->
    <div class="flex items-center gap-2">
      <!-- Lang switch -->
      <a
        href={isEn ? currentPath.replace(/^\/en/, '') || '/' : `/en${currentPath}`}
        class="px-3 py-1.5 rounded-xl text-sm font-medium text-neutral-500 hover:text-neutral-900 hover:bg-neutral-100 transition-colors duration-150"
        aria-label="Switch language"
      >
        {isEn ? '🇵🇱 PL' : '🇬🇧 EN'}
      </a>

      <!-- CTA -->
      <a
        href="https://proompi.com"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex btn-primary text-sm px-4 py-2"
      >
        {isEn ? 'Try Proompi →' : 'Wypróbuj →'}
      </a>
    </div>
  </nav>
</header>
