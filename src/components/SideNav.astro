---
import type { CollectionEntry } from 'astro:content';

interface Props {
  articles: CollectionEntry<'docs'>[];
  currentSlug: string;
  lang: string;
  section: string;
}

const { articles, currentSlug, lang, section } = Astro.props;
const isEn = lang === 'en';
const base = isEn ? '/en' : '';

const sectionMeta: Record<string, { label: string; labelEn: string; color: string }> = {
  'getting-started': { label: 'Pierwsze kroki', labelEn: 'Getting Started', color: 'bg-emerald-50 text-emerald-700' },
  'prompt-enhancement': { label: 'Ulepszanie Promptów', labelEn: 'Prompt Enhancement', color: 'bg-primary-50 text-primary-700' },
  'image-generation': { label: 'Generowanie Obrazów', labelEn: 'Image Generation', color: 'bg-violet-50 text-violet-700' },
  'workflows': { label: 'Workflow Builder', labelEn: 'Workflow Builder', color: 'bg-indigo-50 text-indigo-700' },
  'video-generation': { label: 'Generowanie Wideo', labelEn: 'Video Generation', color: 'bg-rose-50 text-rose-700' },
  'music-generation': { label: 'Generowanie Muzyki', labelEn: 'Music Generation', color: 'bg-orange-50 text-orange-700' },
  'graphics-editing': { label: 'Edycja Grafik', labelEn: 'Graphics Editing', color: 'bg-teal-50 text-teal-700' },
  'plans-credits': { label: 'Plany i Kredyty', labelEn: 'Plans & Credits', color: 'bg-amber-50 text-amber-700' },
  'tips': { label: 'Tips i Triki', labelEn: 'Tips & Tricks', color: 'bg-neutral-100 text-neutral-700' },
};

const meta = sectionMeta[section] ?? { label: section, labelEn: section, color: 'bg-neutral-100 text-neutral-600' };
const sorted = [...articles].sort((a, b) => a.data.order - b.data.order);
---

<aside class="w-full lg:w-64 flex-shrink-0">
  <div class="glass-card p-4 sticky top-24">
    <!-- Section badge -->
    <span class:list={['section-pill mb-4', meta.color]}>
      {isEn ? meta.labelEn : meta.label}
    </span>

    <nav aria-label="Section navigation">
      <ul class="space-y-0.5 mt-2">
        {sorted.map(article => {
          const slugParts = article.slug.split('/');
          const articlePath = slugParts.slice(1).join('/'); // remove lang prefix
          const href = `${base}/${articlePath}`;
          const isCurrent = article.slug === currentSlug;

          return (
            <li>
              <a
                href={href}
                class:list={[
                  'flex items-center gap-2 px-3 py-2 rounded-xl text-sm transition-colors duration-150',
                  isCurrent
                    ? 'bg-primary-50 text-primary-700 font-semibold'
                    : 'text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900'
                ]}
                aria-current={isCurrent ? 'page' : undefined}
              >
                {isCurrent && (
                  <span class="w-1.5 h-1.5 rounded-full bg-primary-500 flex-shrink-0"></span>
                )}
                {article.data.title}
                {article.data.badge && (
                  <span class="ml-auto text-xs bg-primary-100 text-primary-600 px-1.5 py-0.5 rounded-full">
                    {article.data.badge}
                  </span>
                )}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- Back link -->
    <div class="mt-4 pt-4 border-t border-neutral-200">
      <a href={base || '/'} class="flex items-center gap-1.5 text-xs text-neutral-400 hover:text-primary-500 transition-colors">
        ← {isEn ? 'All guides' : 'Wszystkie przewodniki'}
      </a>
    </div>
  </div>
</aside>
