---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import HeroIllustration from '../components/HeroIllustration.astro';
import { getCollection } from 'astro:content';

const allDocs = await getCollection('docs');
const plDocs = allDocs.filter(d => d.data.lang === 'pl');

const sections = [
  { id: 'getting-started',   label: 'Pierwsze kroki',       icon: '🚀', gradient: 'from-emerald-500 to-teal-400',    bg: 'from-emerald-50 to-teal-50',    border: 'border-emerald-200/80', desc: 'Zacznij korzystać z Proompi od podstaw' },
  { id: 'prompt-enhancement',label: 'Ulepszanie Promptów',  icon: '✨', gradient: 'from-violet-500 to-purple-400',   bg: 'from-violet-50 to-purple-50',   border: 'border-violet-200/80',  desc: 'Jak pisać prompty, które dają spektakularne efekty' },
  { id: 'image-generation',  label: 'Generowanie Obrazów',  icon: '🖼️', gradient: 'from-blue-500 to-indigo-400',    bg: 'from-blue-50 to-indigo-50',     border: 'border-blue-200/80',    desc: 'Modele AI, ustawienia i najlepsze praktyki' },
  { id: 'workflows',         label: 'Workflow Builder',     icon: '⚡', gradient: 'from-indigo-500 to-blue-400',    bg: 'from-indigo-50 to-blue-50',     border: 'border-indigo-200/80',  desc: 'Twórz zaawansowane procesy generowania treści' },
  { id: 'video-generation',  label: 'Generowanie Wideo',    icon: '🎬', gradient: 'from-rose-500 to-pink-400',      bg: 'from-rose-50 to-pink-50',       border: 'border-rose-200/80',    desc: 'Sora, Luma, Kling — kiedy co używać' },
  { id: 'music-generation',  label: 'Generowanie Muzyki',   icon: '🎵', gradient: 'from-orange-500 to-amber-400',   bg: 'from-orange-50 to-amber-50',    border: 'border-orange-200/80',  desc: 'Muzyka AI studyjnej jakości w kilka sekund' },
  { id: 'graphics-editing',  label: 'Edycja Grafik',        icon: '🎨', gradient: 'from-teal-500 to-cyan-400',      bg: 'from-teal-50 to-cyan-50',       border: 'border-teal-200/80',    desc: 'Text overlay, wektoryzacja i eksport' },
  { id: 'plans-credits',     label: 'Plany i Kredyty',      icon: '💳', gradient: 'from-amber-500 to-yellow-400',   bg: 'from-amber-50 to-yellow-50',    border: 'border-amber-200/80',   desc: 'Jak działa system kredytów i który plan wybrać' },
  { id: 'tips',              label: 'Tips i Triki',         icon: '💡', gradient: 'from-neutral-500 to-slate-400',  bg: 'from-neutral-50 to-slate-50',   border: 'border-neutral-200/80', desc: 'Szybkie porady i wiedza w pigułce' },
];

const featuredDocs = plDocs
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6);
---

<BaseLayout
  title="Proompi Academy"
  description="Oficjalna baza wiedzy Proompi — tutoriale, poradniki i wskazówki jak tworzyć profesjonalne treści AI. Naucz się generować obrazy, wideo, muzykę i budować workflow."
  lang="pl"
>
  <!-- Hero -->
  <section class="hero-gradient pt-16 pb-20 px-4 overflow-hidden">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-10 items-center">
      <!-- Left: text -->
      <div class="text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-white/80 border border-violet-200 rounded-full text-sm font-medium text-violet-700 mb-6 shadow-sm">
          <span>📚</span> Oficjalna baza wiedzy Proompi
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-neutral-900 leading-[1.1] mb-6 tracking-tight">
          Zostań ekspertem<br>
          <span class="bg-gradient-to-r from-violet-600 to-pink-500 bg-clip-text text-transparent">AI marketingu</span>
        </h1>
        <p class="text-lg sm:text-xl text-neutral-500 max-w-xl mx-auto lg:mx-0 leading-relaxed mb-8">
          Wszystko czego potrzebujesz, żeby w pełni wykorzystać Proompi — od pierwszego logowania po zaawansowane workflow, które zautomatyzują marketing Twojej firmy.
        </p>
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-3">
          <a href="/getting-started" class="btn-primary text-base px-7 py-3.5">
            Zacznij od podstaw →
          </a>
          <a href="https://proompi.com" target="_blank" rel="noopener noreferrer" class="btn-secondary text-base px-7 py-3.5">
            Otwórz Proompi
          </a>
        </div>
      </div>
      <!-- Right: illustration -->
      <div class="hidden lg:flex justify-center lg:justify-end">
        <HeroIllustration />
      </div>
    </div>
  </section>

  <!-- Stats strip -->
  <section class="py-8 px-4 border-y border-neutral-200 bg-white/60">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { value: '9',   label: 'Modułów wiedzy',  icon: '📚' },
        { value: '40+', label: 'Tutoriali',        icon: '🎯' },
        { value: '7',   label: 'Modeli AI',        icon: '🤖' },
        { value: '∞',   label: 'Możliwości',       icon: '✨' },
      ].map(stat => (
        <div class="flex flex-col items-center gap-1">
          <span class="text-xl mb-0.5">{stat.icon}</span>
          <div class="text-2xl font-bold bg-gradient-to-r from-violet-600 to-pink-500 bg-clip-text text-transparent">{stat.value}</div>
          <div class="text-sm text-neutral-500">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Sections grid -->
  <section class="py-16 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-neutral-900 mb-3 tracking-tight">Wybierz temat</h2>
        <p class="text-neutral-500 text-lg">9 modułów — od podstaw po zaawansowane techniki</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {sections.map(section => {
          const count = plDocs.filter(d => d.data.section === section.id).length;
          return (
            <a
              href={`/${section.id}`}
              class:list={[
                'group relative overflow-hidden rounded-3xl border bg-gradient-to-br p-6 flex flex-col gap-4',
                'hover:shadow-float hover:-translate-y-1 transition-all duration-300',
                section.bg,
                section.border,
              ]}
            >
              <!-- Top row: icon + count -->
              <div class="flex items-start justify-between">
                <div class:list={[
                  'w-12 h-12 rounded-2xl flex items-center justify-center text-2xl',
                  'bg-gradient-to-br shadow-sm',
                  section.gradient,
                ]}>
                  <span class="drop-shadow">{section.icon}</span>
                </div>
                {count > 0 && (
                  <span class="text-xs font-medium text-neutral-400 bg-white/70 px-2 py-1 rounded-full border border-white/80">
                    {count} art.
                  </span>
                )}
              </div>
              <!-- Content -->
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-neutral-900 group-hover:text-violet-700 transition-colors leading-snug mb-1.5">
                  {section.label}
                </h3>
                <p class="text-sm text-neutral-500 leading-relaxed">{section.desc}</p>
              </div>
              <!-- CTA row -->
              <div class="flex items-center justify-between">
                <span class="text-sm font-semibold text-violet-600 group-hover:text-violet-700">
                  Przejdź →
                </span>
                <div class="w-8 h-8 rounded-full bg-white/80 border border-white/80 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200 -translate-x-1 group-hover:translate-x-0">
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                    <path d="M2.5 6H9.5M6.5 3L9.5 6L6.5 9" stroke="#7c3aed" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Featured articles -->
  {featuredDocs.length > 0 && (
    <section class="py-12 px-4 bg-white/40">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-neutral-900 tracking-tight">Zacznij od tych przewodników</h2>
          <a href="/getting-started" class="text-sm font-medium text-violet-600 hover:text-violet-700 transition-colors hidden sm:block">
            Zobacz wszystkie →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {featuredDocs.map(article => (
            <ArticleCard article={article} lang="pl" />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Banner -->
  <section class="py-16 px-4">
    <div class="max-w-3xl mx-auto relative overflow-hidden rounded-3xl p-8 sm:p-12 text-center"
         style="background: linear-gradient(135deg, #f5f3ff 0%, #fdf2f8 50%, #eff6ff 100%); border: 1px solid rgba(124,58,237,0.15);">
      <!-- Decorative orbs -->
      <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full opacity-20"
           style="background: radial-gradient(circle, #7c3aed, transparent);"></div>
      <div class="absolute -bottom-10 -left-10 w-40 h-40 rounded-full opacity-15"
           style="background: radial-gradient(circle, #ec4899, transparent);"></div>
      <!-- Content -->
      <div class="relative">
        <div class="text-4xl mb-4">🚀</div>
        <h2 class="text-2xl sm:text-3xl font-bold text-neutral-900 mb-3 tracking-tight">
          Gotowy żeby zacząć?
        </h2>
        <p class="text-neutral-500 mb-8 leading-relaxed max-w-xl mx-auto">
          Proompi to platforma AI do generowania obrazów, wideo i treści dla Twojego biznesu. Dołącz do tysięcy użytkowników.
        </p>
        <a href="https://proompi.com" target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-8 py-4 rounded-full text-white font-bold text-base transition-all duration-200 hover:opacity-90 hover:scale-[1.02] active:scale-[0.98]"
           style="background: linear-gradient(135deg, #7c3aed, #ec4899); box-shadow: 0 8px 32px -4px rgba(124,58,237,0.35);">
          Wypróbuj Proompi za darmo →
        </a>
      </div>
    </div>
  </section>

  <!-- JSON-LD: ItemList of sections -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Proompi Academy — Sekcje",
    "url": "https://academy.proompi.com",
    "itemListElement": sections.map((s, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": s.label,
      "url": `https://academy.proompi.com/${s.id}`,
      "description": s.desc,
    }))
  })} />
</BaseLayout>
